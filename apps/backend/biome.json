{
	"root": false,
	"extends": "//",
	"files": {
		"includes": ["**", "!prisma", "!dist", "!compodoc", "!node_modules"]
	},
	"linter": {
		"rules": {
			"style": {
				"noNonNullAssertion": "error",
				"useImportType": "error"
			},
			"suspicious": {
				"noExplicitAny": "error",
				"noThenProperty": "error",
				"noShadowRestrictedNames": "off"
			}
		}
	},
	"javascript": {
		"parser": {
			"unsafeParameterDecoratorsEnabled": true
		}
	}
}
