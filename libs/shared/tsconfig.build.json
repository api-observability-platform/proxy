{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"module": "commonjs",
		"moduleResolution": "bundler",
		"noEmit": false,
		"outDir": "dist",
		"rootDir": "src",
		"declaration": true,
		"declarationMap": true,
		"incremental": true,
		"tsBuildInfoFile": "./dist/.tsbuildinfo.build",
		"noEmitOnError": true,
		"removeComments": true,
		"esModuleInterop": true
	},
	"include": ["src/**/*.ts"]
}
